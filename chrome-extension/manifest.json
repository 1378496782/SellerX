{
  "manifest_version": 3,
  "name": "SellerX",
  "version": "1.1.3",
  "description": "批量管理和删除 TikTok Shop Seller 店铺的促销活动",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://*.tiktok.net/*",
    "https://*.tokopedia.com/*",
    "https://*.tokopedia.net/*",
    "https://*.tiktokv.com/*",
    "https://github.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "update_url": "https://raw.githubusercontent.com/1378496782/SellerX/main/chrome-extension/update.xml"
}
